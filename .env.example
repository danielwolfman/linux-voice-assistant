# Linux Realtime satellite environment example

# Core identity
# LVA_NAME="Berta"

# Audio devices
# LVA_AUDIO_INPUT_DEVICE="default"
# LVA_AUDIO_OUTPUT_DEVICE="default"
# LVA_AUDIO_INPUT_BLOCK_SIZE="1024"

# Wake word configuration
# LVA_WAKE_WORD_DIR="wakewords"
# LVA_WAKE_MODEL="okay_nabu"
# LVA_STOP_MODEL="stop"
# LVA_DOWNLOAD_DIR="local"
# LVA_WAKEUP_SOUND="sounds/wake_word_triggered.flac"
# LVA_REFRACTORY_SECONDS="2"

# OpenAI Realtime
OPENAI_API_KEY=""
# LVA_OPENAI_MODEL="gpt-realtime"
# LVA_OPENAI_VOICE="marin"
# LVA_OPENAI_API_BASE=""

# Home Assistant
HOME_ASSISTANT_URL="http://homeassistant.local:8123"
HOME_ASSISTANT_TOKEN=""
# LVA_HA_VERIFY_SSL="0"

# Runtime behavior
# LVA_SESSION_TIMEOUT_SECONDS="20"
# LVA_VAD_THRESHOLD="0.015"
# LVA_MIN_SPEECH_SECONDS="0.2"
# LVA_END_SILENCE_SECONDS="0.8"

# Files
# LVA_PREFERENCES_FILE="preferences.json"
# LVA_CONFIG="examples/realtime-home-assistant.yaml"

# Logging
# LVA_DEBUG="1"
